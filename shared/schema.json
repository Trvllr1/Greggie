{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GreggieFeedItem",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "user_id": { "type": "string" },
    "source": {
      "type": "object",
      "properties": {
        "platform": { "enum": ["instagram", "tiktok", "youtube", "open-web"] },
        "origin_url": { "type": "string", "format": "uri" },
        "badge_color": { "type": "string" }
      }
    },
    "content": {
      "type": "object",
      "properties": {
        "author_handle": { "type": "string" },
        "caption": { "type": "string" },
        "media_url": { "type": "string", "format": "uri" },
        "is_video": { "type": "boolean" },
        "embed_html": { "type": "string" }
      }
    },
    "collected_at": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "source", "content"]
}
