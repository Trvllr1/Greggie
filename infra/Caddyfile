{
	default_sni 137.131.51.134
}

https://137.131.51.134 {
	tls internal
	log {
		output stdout
		format console
	}

	handle /api/* {
		reverse_proxy backend:8080
	}

	@websocket {
		path /ws /ws/*
	}
	handle @websocket {
		reverse_proxy backend:8080
	}

	handle /health {
		reverse_proxy backend:8080
	}

	handle /whip/* {
		@options method OPTIONS
		handle @options {
			header Access-Control-Allow-Origin *
			header Access-Control-Allow-Methods "POST, DELETE, OPTIONS, PATCH"
			header Access-Control-Allow-Headers "Content-Type, Authorization"
			header Access-Control-Expose-Headers "Location, Link"
			respond 204
		}
		uri strip_prefix /whip
		reverse_proxy mediamtx:8889
		header Access-Control-Allow-Origin *
		header Access-Control-Allow-Methods "POST, DELETE, OPTIONS, PATCH"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		header Access-Control-Expose-Headers "Location, Link"
	}

	handle /hls/* {
		uri strip_prefix /hls
		reverse_proxy mediamtx:8888
		header Access-Control-Allow-Origin *
		# CDN-ready cache policy:
		#   .m3u8 playlists update every ~1s — keep TTL tiny but cacheable for fanout
		#   .m4s/.ts segments are immutable — cache aggressively
		# Flip CDN on by pointing DNS at Cloudflare/Bunny in front of this host.
		@playlist path *.m3u8
		header @playlist Cache-Control "public, max-age=1, s-maxage=2"
		@segment path *.m4s *.ts *.mp4
		header @segment Cache-Control "public, max-age=3600, immutable"
	}

	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server

		@html path / /index.html
		header @html Cache-Control "no-cache, no-store, must-revalidate"
	}
}

# Redirect HTTP → HTTPS
:80 {
	redir https://{host}{uri} permanent
}
