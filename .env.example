# Greggie Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── Core ──────────────────────────────────────────
ENVIRONMENT=dev
JWT_SECRET=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# ── Database ──────────────────────────────────────
POSTGRES_USER=greggie
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=greggie

# ── Caddy / Domain ───────────────────────────────
# Set to your domain for auto-TLS, or leave as IP for HTTP-only
DOMAIN=:80

# ── Stripe (optional in dev) ─────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── S3 Storage (optional — uploads disabled if empty) ──
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ── MediaMTX (disabled on Micro VM — uncomment when on ARM) ──
# MEDIAMTX_URL=http://mediamtx:9997
